{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-test-build",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app/lib/game/**/*.ts",
    "scripts_test_game_engine.ts"
  ],
  "exclude": ["node_modules"]
}
